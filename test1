```python
import anthropic

client = anthropic.Anthropic()

message = client.messages.create(
    model="claude-sonnet-4-20250514",
    max_tokens=1024,
    messages=[
        {
            "role": "user",
            "content": "Arrange the list of Cities in ascending order - Mumbai, Pune, Bengaluru, Hyderabad, Noida.",
        }
    ],
)

print(message.content[0].text)
```